---
import BaseLayout from '../layouts/BaseLayout.astro';

const base = import.meta.env.BASE_URL;

const courses = [
  {
    id: 'damodaran-valuation',
    title: 'Damodaran Valuation',
    subtitle: 'ศิลปะและศาสตร์แห่งการประเมินมูลค่าธุรกิจ',
    emoji: '🎓',
    chapters: 12,
    description: 'หลักสูตร 12 บท โดย Prof. Aswath Damodaran - Dean of Valuation จาก NYU Stern School of Business',
    topics: ['DCF Valuation', 'Relative Valuation', 'หุ้นไทย']
  },
  {
    id: 'seth-klarman-margin-of-safety',
    title: 'Seth Klarman: Margin of Safety',
    subtitle: 'Value Investing แบบ Conservative',
    emoji: '🛡️',
    chapters: 10,
    description: 'หลักสูตร 10 บท โดย Seth Klarman - ผู้จัดการกองทุน Baupost Group และผู้เขียนหนังสือ Margin of Safety',
    topics: ['Risk Management', 'Value Investing', 'Contrarian Thinking']
  },
  {
    id: '10k-running-training',
    title: '10K Running Training',
    subtitle: 'แนวทางการพัฒนานักวิ่ง 10K ที่เก่งที่สุด',
    emoji: '🏃',
    chapters: 1,
    description: 'Evidence-Based Training Guide - อ้างอิงจากงานวิจัยทางวิทยาศาสตร์ เน้น Polarized Training (80/20)',
    topics: ['Polarized Training', 'Periodization', 'Evidence-Based']
  }
];
---

<BaseLayout title="หน้าแรก" description="Episteme - แพลตฟอร์มเรียนรู้">
  <!-- Cover Section -->
  <section class="hero">
    <div class="hero-content">
      <div class="hero-badge">📚 Episteme</div>
      <h1>แพลตฟอร์มเรียนรู้</h1>
      <p class="hero-subtitle">ความรู้ที่จัดสรรไว้เพื่อคุณ</p>
    </div>
    <div class="hero-pattern"></div>
  </section>

  <!-- Courses Section -->
  <section class="courses-section">
    <div class="section-header">
      <h2>📖 คอร์สทั้งหมด</h2>
      <p>เลือกคอร์สที่คุณสนใจ</p>
    </div>

    <div class="courses-grid">
      {courses.map(course => (
        <a href={`${base}/courses/${course.id}/`} class="course-card">
          <div class="course-emoji">{course.emoji}</div>
          <h3 class="course-title">{course.title}</h3>
          <p class="course-subtitle">{course.subtitle}</p>
          <p class="course-description">{course.description}</p>

          <div class="course-topics">
            {course.topics.map(topic => (
              <span class="topic-tag">{topic}</span>
            ))}
          </div>

          <div class="course-meta">
            <span class="chapter-count">📝 {course.chapters} บท</span>
            <span class="start-btn">เริ่มเรียน →</span>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- Features Section -->
  <section class="features-section">
    <h2>✨ สิ่งที่คุณจะได้</h2>
    <div class="features-grid">
      <div class="feature-card">
        <div class="feature-icon">📊</div>
        <h3>ติดตามความก้าวหน้า</h3>
        <p>เห็นว่าเรียนไปแล้วกี่ % และบทไหนที่ยังไม่ได้เรียน</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon">📝</div>
        <h3>Quiz ท้ายบท</h3>
        <p>ทดสอบความเข้าใจหลังจากอ่านแต่ละบท</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon">🔍</div>
        <h3>ค้นหาเนื้อหา</h3>
        <p>ค้นหาทุกบทเรียนได้จากที่เดียว</p>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="footer">
    <div class="footer-content">
      <p class="footer-brand">📚 Episteme</p>
      <p class="footer-tagline">ความรู้คือพลัง • Knowledge is Power</p>
      <p class="footer-note">อัปเดตล่าสุด: 15 มีนาคม 2026</p>
    </div>
  </footer>
</BaseLayout>

<style>
  /* Hero Section */
  .hero {
    background: linear-gradient(135deg, #1a365d 0%, #2c5282 50%, #2b6cb0 100%);
    color: white;
    padding: 80px 20px;
    text-align: center;
    position: relative;
    overflow: hidden;
    border-radius: var(--radius-xl);
    margin-bottom: 40px;
  }

  .hero-pattern {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.05'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
    pointer-events: none;
  }

  .hero-content {
    position: relative;
    z-index: 1;
    max-width: 600px;
    margin: 0 auto;
  }

  .hero-badge {
    display: inline-block;
    background: rgba(255,255,255,0.15);
    padding: 8px 20px;
    border-radius: 30px;
    font-size: 0.9em;
    margin-bottom: 20px;
    backdrop-filter: blur(10px);
  }

  .hero h1 {
    font-size: 3em;
    font-weight: 700;
    margin-bottom: 15px;
    text-shadow: 2px 2px 4px rgba(0,0,0,0.2);
  }

  .hero-subtitle {
    font-size: 1.2em;
    opacity: 0.9;
  }

  /* Courses Section */
  .courses-section {
    padding: 40px 20px;
    max-width: 1000px;
    margin: 0 auto;
  }

  .section-header {
    text-align: center;
    margin-bottom: 40px;
  }

  .section-header h2 {
    font-size: 1.8em;
    color: #1a365d;
    margin-bottom: 10px;
  }

  .section-header p {
    color: #718096;
  }

  .courses-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(400px, 1fr));
    gap: 30px;
  }

  @media (max-width: 500px) {
    .courses-grid {
      grid-template-columns: 1fr;
    }
  }

  .course-card {
    background: white;
    border-radius: var(--radius-lg);
    padding: 35px;
    text-decoration: none;
    color: inherit;
    display: block;
    transition: all 0.3s ease;
    box-shadow: var(--shadow-sm);
    border: 2px solid transparent;
  }

  .course-card:hover {
    transform: translateY(-8px);
    box-shadow: var(--shadow-md);
    border-color: #2b6cb0;
  }

  .course-emoji {
    font-size: 3em;
    margin-bottom: 20px;
  }

  .course-title {
    color: #1a365d;
    font-size: 1.5em;
    margin-bottom: 8px;
    font-weight: 700;
  }

  .course-subtitle {
    color: #2b6cb0;
    font-size: 1em;
    margin-bottom: 15px;
    font-weight: 500;
  }

  .course-description {
    color: #4a5568;
    font-size: 0.95em;
    margin-bottom: 20px;
    line-height: 1.6;
  }

  .course-topics {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 25px;
  }

  .topic-tag {
    background: #ebf8ff;
    color: #2b6cb0;
    padding: 6px 14px;
    border-radius: 20px;
    font-size: 0.85em;
    font-weight: 500;
  }

  .course-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 20px;
    border-top: 1px solid #e2e8f0;
  }

  .chapter-count {
    color: #718096;
    font-size: 0.9em;
  }

  .start-btn {
    background: linear-gradient(135deg, #1a365d 0%, #2c5282 100%);
    color: white;
    padding: 10px 20px;
    border-radius: var(--radius-md);
    font-weight: 600;
    font-size: 0.9em;
    transition: all 0.3s ease;
  }

  .course-card:hover .start-btn {
    background: linear-gradient(135deg, #38a169 0%, #48bb78 100%);
  }

  /* Features Section */
  .features-section {
    background: white;
    padding: 60px 20px;
    border-radius: var(--radius-xl);
    max-width: 1000px;
    margin: 40px auto;
  }

  .features-section h2 {
    text-align: center;
    font-size: 1.8em;
    color: #1a365d;
    margin-bottom: 40px;
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 30px;
    max-width: 900px;
    margin: 0 auto;
  }

  .feature-card {
    text-align: center;
    padding: 30px 20px;
    border-radius: var(--radius-lg);
    background: #f7fafc;
    transition: all 0.3s ease;
  }

  .feature-card:hover {
    background: #ebf8ff;
    transform: translateY(-5px);
  }

  .feature-icon {
    font-size: 3em;
    margin-bottom: 15px;
  }

  .feature-card h3 {
    color: #1a365d;
    margin-bottom: 10px;
    font-size: 1.1em;
  }

  .feature-card p {
    color: #718096;
    font-size: 0.9em;
    line-height: 1.6;
  }

  /* Footer */
  .footer {
    text-align: center;
    padding: 50px 20px;
    margin-top: 40px;
  }

  .footer-brand {
    font-size: 1.5em;
    font-weight: 700;
    color: #1a365d;
    margin-bottom: 10px;
  }

  .footer-tagline {
    color: #718096;
    margin-bottom: 15px;
  }

  .footer-note {
    color: #a0aec0;
    font-size: 0.85em;
  }
</style>
