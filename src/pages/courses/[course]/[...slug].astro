---
import { getCollection, render } from 'astro:content';
import CourseLayout from '../../../layouts/CourseLayout.astro';
import Quiz from '../../../components/Quiz';

export async function getStaticPaths() {
  const courses = await getCollection('courses');

  const paths = [];

  for (const entry of courses) {
    if (!entry.data.chapter) continue; // Only chapter entries, not index

    const rawSlug = entry.id.split('/').pop();
    const slug = rawSlug.replace('.md', '');
    const { Content } = await render(entry);

    paths.push({
      params: {
        course: entry.data.course,
        slug: slug
      },
      props: {
        ...entry.data,
        Content
      }
    });
  }

  return paths;
}

const { title, course, chapter, Content } = Astro.props;
---

<CourseLayout title={title} course={course} chapter={chapter}>
  <h1>{title}</h1>
  <div class="content">
    <Content />
  </div>

  <!-- Progress marker -->
  <div class="chapter-progress" data-chapter={chapter} data-course={course}></div>
</CourseLayout>

<style>
  .content :global(h2) {
    color: var(--color-success);
    margin-top: 30px;
    margin-bottom: 15px;
  }

  .content :global(h3) {
    color: var(--color-accent);
    margin-top: 25px;
    margin-bottom: 12px;
  }

  .content :global(p) {
    color: var(--text-secondary);
    margin-bottom: 15px;
    line-height: 1.8;
  }

  .content :global(ul),
  .content :global(ol) {
    padding-left: 25px;
    margin-bottom: 15px;
  }

  .content :global(li) {
    color: var(--text-secondary);
    margin-bottom: 8px;
    line-height: 1.7;
  }

  .content :global(code) {
    background: var(--bg-input);
    padding: 2px 6px;
    border-radius: 4px;
    font-family: 'Fira Code', monospace;
    font-size: 0.9em;
  }

  .content :global(pre) {
    background: var(--bg-card-inner);
    padding: 20px;
    border-radius: var(--radius-md);
    overflow-x: auto;
    margin-bottom: 20px;
  }

  .content :global(pre code) {
    background: none;
    padding: 0;
  }

  .content :global(blockquote) {
    border-left: 4px solid var(--color-accent);
    padding-left: 20px;
    margin: 25px 0;
    color: var(--text-muted);
    font-style: italic;
  }

  .content :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 20px 0;
  }

  .content :global(th),
  .content :global(td) {
    padding: 12px 15px;
    text-align: left;
    border-bottom: 1px solid var(--bg-input);
  }

  .content :global(th) {
    color: var(--color-accent);
    font-weight: 600;
  }

  .content :global(td) {
    color: var(--text-secondary);
  }

  .content :global(a) {
    color: var(--color-accent);
    text-decoration: none;
  }

  .content :global(a:hover) {
    text-decoration: underline;
  }

  .content :global(hr) {
    border: none;
    border-top: 1px solid var(--bg-input);
    margin: 30px 0;
  }

  .chapter-progress {
    display: none;
  }
</style>
